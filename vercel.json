{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "public",
  "rewrites": [
    { "source": "/", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/morning",
      "schedule": "30 3 * * 1-5"
    },
    {
      "path": "/api/cron/eod",
      "schedule": "30 9 * * 1-5"
    },
    {
      "path": "/api/cron/weekly",
      "schedule": "0 10 * * 5"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  }
}
