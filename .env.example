# Copy this file to .env.local for local dev (vercel dev uses it).
# For production, add these in Vercel Dashboard → Settings → Environment Variables.

# === GitHub ===
# Create a Personal Access Token here:
# https://github.com/settings/tokens/new?scopes=repo,read:project,write:repo_hook
GITHUB_TOKEN=ghp_paste_your_token_here
GITHUB_REPO=your-org/your-repo
GITHUB_WEBHOOK_SECRET=any_random_string_choose_one

# === AI (Gemini Free API) ===
# Get free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=paste_your_gemini_key_here
AI_MODEL=gemini-2.0-flash

# === Discord ===
# Get webhook URL from your channel → Edit → Integrations → Webhooks
DISCORD_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy
# (Optional) Discord server ID for widget embed (Server Settings → Widget → Server ID)
DISCORD_SERVER_ID=

# === Email (Gmail SMTP) ===
# Need App Password (not real password). 2FA must be on.
# https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=abcdefghijklmnop
EMAIL_TO=pm@example.com,lead@example.com

# === Google Sheets ===
# "Publish to web → Comma-separated values" then paste the URL here.
# (Or paste the spreadsheet ID and we'll handle it.)
GOOGLE_SHEETS_URL=https://docs.google.com/spreadsheets/d/e/PUBLISHED_ID/pub?output=csv

# === Auto-assign config (JSON string) ===
# Map dev GitHub usernames to skills + max workload
# Example:
# {"dev1":{"skills":["frontend","react"],"max_open":3},"dev2":{"skills":["backend","python"],"max_open":4}}
TEAM_CONFIG={"dev1-username":{"skills":["frontend"],"max_open":3},"dev2-username":{"skills":["backend"],"max_open":3}}

# === Project info (shown in reports) ===
PROJECT_NAME=ShopWithMe Enrollment
TIMEZONE=Asia/Hong_Kong
